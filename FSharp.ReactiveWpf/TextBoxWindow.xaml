<metro:MetroWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    Title="Change Current Value"
    Width="500"
    Height="400"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  TextBox  -->
        <TextBox
            x:Name="textbox"
            Grid.Row="0"
            Margin="0,0,0,20"
            metro:TextBoxHelper.ClearTextButton="True"
            metro:TextBoxHelper.Watermark="请输入内容"
            FontSize="14" />

        <!--  按钮区域  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="confirm"
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Content="确认"
                IsDefault="True" />

            <Button
                x:Name="cancel"
                Width="80"
                Height="30"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>

</metro:MetroWindow>



